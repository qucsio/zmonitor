APP_ENV=dev
DEBUG=true
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1,web

DATABASE_URL=postgres://arb:arb@postgres:5432/arbscanner
REDIS_URL=redis://redis:6379/0

DISCOVERY_INTERVAL_SEC=300
MATCHING_INTERVAL_SEC=30

ORDERBOOK_MODE=rest
ORDERBOOK_REFRESH_SEC=1
ORDERBOOK_REST_RESYNC_SEC=30

STALE_BOOK_MS=2000

OPPORTUNITY_NET_EDGE_THRESHOLD=0.01
OPPORTUNITY_EDGE_POINT_INTERVAL_SEC=1
EDGE_POINT_DELTA_THRESHOLD=0.001

DEFAULT_FEE_BUFFER=0.005
DEFAULT_SLIPPAGE_BUFFER=0.005

VWAP_SIZES_USD=10,25,50,100,250,500,1000

POLYMARKET_ENABLED=true
POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE=https://clob.polymarket.com
POLYMARKET_WS_MARKET_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
# Optional outbound proxy for Polymarket (usually not needed). e.g. http://user:pass@host:port
POLYMARKET_PROXY_URL=

KALSHI_ENABLED=true
KALSHI_ENV=prod
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2
KALSHI_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
# Required if your server IP is geo-blocked by Kalshi/CloudFront (403).
# Route Kalshi traffic via a proxy in an allowed region (e.g. US).
# Format: http://user:pass@host:port  or  socks5://user:pass@host:port
KALSHI_PROXY_URL=

LLM_MATCHING_ENABLED=false
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:3b
